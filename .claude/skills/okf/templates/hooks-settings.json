{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "test -f {WIKI}/index.md && printf '%s\\n' 'OKF knowledge base active: read {WIKI}/index.md first; follow relative links. Persist durable findings to {WIKI}/ as you work (single writer; subagents read-only). Obligations: AGENTS.md -> ## Knowledge base.' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .okf/lint.py ]; then python3 .okf/lint.py hook; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .okf/lint.py ]; then python3 .okf/lint.py stop-gate; fi"
          }
        ]
      }
    ]
  }
}
